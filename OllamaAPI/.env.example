# Ollama Cloud configuration
# Host of the Ollama Cloud endpoint.
OLLAMA_HOST=https://ollama.com

# API key for Ollama Cloud (sent as an "Authorization: Bearer <key>" header).
# Create one at https://ollama.com/settings/keys.
OLLAMA_API_KEY=your-ollama-api-key-here

# Model to use for generation (must be available on Ollama Cloud).
OLLAMA_MODEL=gemma4:cloud

# Node/Fastify backend that owns the SQLite database
BACKEND_URL=http://localhost:8080

# Flask server port
PORT=5000
